/* ═══════════════════════════════════════════
   THEME: Pearl White front, Dark contrast
═══════════════════════════════════════════ */
:root {
  /* LIGHT SIDE — pearl white */
  --pearl:      #f8f6f1;
  --pearl-2:    #f0ece4;
  --pearl-3:    #e8e2d6;
