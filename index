  --gold-hi:    #dba840;
  --gold-pale:  #f0cc78;
  --gold-glow:  rgba(196,146,48,.18);

  /* TEXT ON LIGHT BG */
  --text-on-light:     #1a1714;
  --text-sub-on-light: #4a443a;
  --text-dim-on-light: #7a7268;

  /* TEXT ON DARK BG */
  --text-on-dark:      #f0ece4;
  --text-sub-on-dark:  #b0a898;
  --text-dim-on-dark:  #6a6258;

  --border-light: rgba(0,0,0,.1);
  --border-gold:  rgba(196,146,48,.25);
  --border-dark:  rgba(255,255,255,.08);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
